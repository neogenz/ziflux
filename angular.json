{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "pnpm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "ziflux": {
      "projectType": "library",
      "root": "projects/ziflux",
      "sourceRoot": "projects/ziflux/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/ziflux/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/ziflux/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/ziflux/tsconfig.spec.json"
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": ["projects/ziflux/**/*.ts", "projects/ziflux/**/*.html"]
          }
        }
      }
    }
  }
}
